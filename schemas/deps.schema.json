{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "deplar dependency manifest",
  "type": "object",
  "required": ["version", "scanned_at", "repo", "dependencies", "summary"],
  "properties": {
    "version": { "type": "string" },
    "scanned_at": { "type": "string", "format": "date-time" },
    "repo": {
      "type": "object",
      "required": ["name", "path"],
      "properties": {
        "name":             { "type": "string" },
        "path":             { "type": "string" },
        "primary_language": { "type": "string" }
      }
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "types", "confidence", "evidence"],
        "properties": {
          "from":       { "type": "string" },
          "to":         { "type": "string" },
          "types": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["import", "http", "feign", "grpc", "kafka", "rabbitmq"]
            }
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "file":    { "type": "string" },
                "line":    { "type": "integer" },
                "snippet": { "type": "string" }
              }
            }
          },
          "metadata": { "type": "object" }
        }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "total_deps":        { "type": "integer" },
        "high_confidence":   { "type": "integer" },
        "services_called":   { "type": "array", "items": { "type": "string" } },
        "services_calling_me": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}