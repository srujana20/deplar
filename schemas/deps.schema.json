{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "deplar dependency manifest",
  "type": "object",
  "required": ["version", "scanned_at", "repo", "dependencies", "summary"],
  "properties": {
    "version": { "type": "string" },
    "scanned_at": { "type": "string", "format": "date-time" },
    "repo": {
      "type": "object",
      "required": ["name", "path"],
      "properties": {
        "name":             { "type": "string" },
        "path":             { "type": "string" },
        "primary_language": { "type": "string" }
      }
    },
    "dependencies": {
      "description": "One unified edge schema for every outbound dependency. `types` is the discriminator (http, soap, feign, grpc, kafka, rabbitmq, db, import); `surfaces` carries the channel-specific contract detail — HTTP endpoints today, and datastore descriptors (host/db/table) for `db` edges when that signal lands. db and http share this shape so a consumer treats every dependency uniformly.",
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from", "to", "types", "confidence", "evidence"],
        "properties": {
          "from":       { "type": "string" },
          "to":         { "type": "string" },
          "types": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": ["import", "http", "soap", "feign", "grpc", "kafka", "rabbitmq", "db"]
            }
          },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "tier": {
            "description": "Provenance of the strongest signal. call-site: literal/resolved URL at a recognized network call (highest). config: URL declared in a config/properties file (high). inferred: call site whose host could not be resolved (low). import: a code import (weak).",
            "type": "string",
            "enum": ["call-site", "config", "inferred", "import", ""]
          },
          "evidence": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "file":    { "type": "string" },
                "line":    { "type": "integer" },
                "snippet": { "type": "string" }
              }
            }
          },
          "surfaces": {
            "description": "Channel-specific contract detail; for http/soap/feign these are the endpoints hit on the provider.",
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "channel":  { "type": "string" },
                "method":   { "type": "string" },
                "path":     { "type": "string" },
                "key":      { "type": "string" },
                "matched":  { "type": "boolean" },
                "match_kind": { "type": "string", "enum": ["exact", "prefix", "none"], "description": "How the call bound to the provider route: exact path, a segment-suffix prefix fallback (differing base/context path), or none." },
                "evidence": { "type": "string" }
              }
            }
          },
          "metadata": { "type": "object" }
        }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "total_deps":        { "type": "integer" },
        "high_confidence":   { "type": "integer" },
        "services_called":   { "type": "array", "items": { "type": "string" } },
        "services_calling_me": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}